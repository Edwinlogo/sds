<!-- CONTACT -->
<section class="sec" id="contact">
  <div class="sec-hdr rv">
    <div class="eyebrow" data-i18n="contact_eyebrow">Get In Touch</div>
    <h2 class="sec-title" data-i18n="contact_title">Start a Conversation</h2>
    <p class="sec-sub" data-i18n="contact_sub">Whether you represent a school district, a transport broker, or a charter institution — our operations team will respond within 24 business hours.</p>
  </div>
  <div class="contact-grid">
    <div class="contact-cards">
      <div class="cc rv"><div class="cc-ico"><img src="https://cdn-icons-gif.flaticon.com/8761/8761723.gif" alt="Phone"/></div><div><h4 data-i18n="cc1_h">Phone</h4><p>+1 (407) 820-1996</p></div></div>
      <div class="cc rv d1"><div class="cc-ico"><img src="https://cdn-icons-gif.flaticon.com/8717/8717907.gif" alt="Email"/></div><div><h4 data-i18n="cc2_h">Email</h4><p>info@safedriveservice.com</p></div></div>
      <div class="cc rv d2"><div class="cc-ico"><img src="https://cdn-icons-gif.flaticon.com/6839/6839004.gif" alt="Location"/></div><div><h4 data-i18n="cc3_h">Location</h4><p data-i18n="cc3_p">Florida, USA · Multi-State Operations</p></div></div>
      <a href="#drive-with-us" class="cc rv d3" style="cursor:pointer;"><div class="cc-ico"><img src="https://cdn-icons-gif.flaticon.com/13470/13470918.gif" alt="Careers"/></div><div><h4 data-i18n="cc4_h">Careers</h4><p style="color:var(--accent);font-weight:600;" data-i18n="cc4_p">Apply to drive with us →</p></div></a>
    </div>
    <div class="cf-box rv d1">
      <h3 data-i18n="form_title">Send Us a Message</h3>
      <div class="f-row">
        <div class="field"><label data-i18n="f_fname">First Name</label><input type="text" data-i18n-ph="ph_fname" placeholder="Maria"/></div>
        <div class="field"><label data-i18n="f_lname">Last Name</label><input type="text" data-i18n-ph="ph_lname" placeholder="Lopez"/></div>
      </div>
      <div class="field"><label data-i18n="f_email">Email</label><input type="email" placeholder="contact@district.edu"/></div>
      <div class="field"><label data-i18n="f_phone">Phone</label><input type="tel" placeholder="+1 (407) 000-0000"/></div>
      <div class="field">
        <label data-i18n="f_iam">I represent a...</label>
        <select>
          <option data-i18n="f_opt1">School District</option>
          <option data-i18n="f_opt2">Transport Broker</option>
          <option data-i18n="f_opt3">Charter / Private School</option>
          <option data-i18n="f_opt4">Other Institution</option>
          <option data-i18n="f_opt5">Prospective Driver</option>
        </select>
      </div>
      <div class="field"><label data-i18n="f_msg">Message</label><textarea data-i18n-ph="ph_msg" placeholder="Describe your operational needs..."></textarea></div>
      <button class="btn btn-primary f-submit" data-i18n="f_submit">Send Message →</button>
    </div>
  </div>
</section>

