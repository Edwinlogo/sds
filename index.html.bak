</div>

<!-- HERO -->
<section id="home">
  <div class="hero">
    <div class="hero-bg-static"></div>
    <div class="hero-video-wrap" id="heroVideoWrap">
      <video id="heroBgVideo" autoplay muted loop playsinline preload="auto">
        <source src="https://safedrivesds.com/media/0306.mp4" type="video/mp4"/>
      </video>
    </div>
    <div class="hero-content">
      <div class="hero-eyebrow rv" data-i18n="hero_eyebrow">B2B Institutional Transportation · 4 Years · Multi-State</div>
      <h1 class="rv d1">
        <span data-i18n="hero_h1a">Operational Stability</span><br>
        <em data-i18n="hero_h1b">Districts Can Measure.</em><br>
        <span data-i18n="hero_h1c">Risks They Won't Have to Manage.</span>
      </h1>
      <p class="rv d2" data-i18n="hero_p">Safe Drive Services is a structured B2B operator delivering compliant, trackable student transportation for school districts, transport brokers, and charter institutions across multiple states.</p>
      <div class="hero-ctas rv d3">
        <a href="#partners" class="btn btn-primary" data-i18n="hero_cta1">Our Partners →</a>
        <a href="#contact" class="btn btn-ghost" data-i18n="hero_cta2">Request a Meeting</a>
      </div>
      <div class="hero-stats rv d4">
        <div class="hstat"><div class="n">95%</div><div class="l" data-i18n="stat1">On-Time Standard</div></div>
        <div class="hstat"><div class="n">4</div><div class="l" data-i18n="stat2">Years Operating</div></div>
        <div class="hstat"><div class="n">15+</div><div class="l" data-i18n="stat3">States</div></div>
        <div class="hstat"><div class="n">B2B</div><div class="l" data-i18n="stat4">Institutional Only</div></div>
      </div>
    </div>
  </div>
</section>

<!-- TRUST BAR -->
<div class="trust-bar">
  <div class="trust-item"><span>🏫</span><span data-i18n="tb1">School Districts</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span>🔗</span><span data-i18n="tb2">Transport Brokers</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span>🎓</span><span data-i18n="tb3">Charter &amp; Private Schools</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span>📋</span><span data-i18n="tb4">Regulatory Compliance</span></div>
  <div class="trust-sep"></div>
  <div class="trust-item"><span>📊</span><span data-i18n="tb5">Verified Metrics</span></div>
</div>

<!-- METRICS -->
<section id="metrics">
  <div class="metrics-inner">
    <div class="metric-item rv"><div class="metric-n">95<sup>%</sup></div><div class="metric-l" data-i18n="m1">On-Time Rate<br>Operational Standard</div></div>
    <div class="metrics-sep"></div>
    <div class="metric-item rv d1"><div class="metric-n">4</div><div class="metric-l" data-i18n="m2">Years of Multi-State<br>Structured Operation</div></div>
    <div class="metrics-sep"></div>
    <div class="metric-item rv d2"><div class="metric-n">0</div><div class="metric-l" data-i18n="m3">Tolerance for<br>Regulatory Non-Compliance</div></div>
    <div class="metrics-sep"></div>
    <div class="metric-item rv d3"><div class="metric-n">15<sup>+</sup></div><div class="metric-l" data-i18n="m4">States with Active<br>Operations</div></div>
  </div>
</section>

<!-- PARTNERS / TABS -->
<section class="sec" id="partners">
  <div class="sec-hdr rv">
    <div class="eyebrow" data-i18n="part_eyebrow">Strategic Partners</div>
    <h2 class="sec-title" data-i18n="part_title">Built for Institutional Operations</h2>
    <p class="sec-sub" data-i18n="part_sub">Safe Drive operates exclusively B2B. Select your profile to see how we reduce operational risk for your organization.</p>
  </div>
  <div class="tab-nav rv d1">
    <button class="tab-btn active" data-tab="districts"><img src="https://cdn-icons-gif.flaticon.com/6454/6454236.gif" alt=""/><span data-i18n="tab_districts">School Districts</span></button>
    <button class="tab-btn" data-tab="brokers"><img src="https://cdn-icons-gif.flaticon.com/17576/17576949.gif" alt=""/><span data-i18n="tab_brokers">Transport Brokers</span></button>
    <button class="tab-btn" data-tab="charter"><img src="https://cdn-icons-gif.flaticon.com/6454/6454106.gif" alt=""/><span data-i18n="tab_charter">Charter &amp; Private Schools</span></button>
  </div>

  <div class="tab-panel active" id="tab-districts">
    <div class="tab-text rv">
      <div class="eyebrow" data-i18n="td_ey">For School Districts</div>
      <h3 class="tab-title" data-i18n="td_title">Reduce Legal Exposure.<br>Guarantee Contractual Compliance.</h3>
      <p class="tab-body" data-i18n="td_body">School districts face regulatory pressure, parent complaints, and liability exposure with every route. Safe Drive provides a structured operator with defined protocols, measurable punctuality, and full state-level regulatory compliance — eliminating the operational chaos that districts cannot afford.</p>
      <ul class="value-list">
        <li><div class="vico">✓</div><div><strong data-i18n="td_v1h">Regulatory compliance per jurisdiction</strong> — <span data-i18n="td_v1p">Every state operates under its specific regulations. No exceptions.</span></div></li>
        <li><div class="vico">✓</div><div><strong data-i18n="td_v2h">95% on-time standard</strong> — <span data-i18n="td_v2p">A measurable, contractual metric, not a marketing claim.</span></div></li>
        <li><div class="vico">✓</div><div><strong data-i18n="td_v3h">Sensitive case handling</strong> — <span data-i18n="td_v3p">Trained staff for special needs students with defined protocols.</span></div></li>
        <li><div class="vico">✓</div><div><strong data-i18n="td_v4h">Incident reduction</strong> — <span data-i18n="td_v4p">Structured operation that minimizes complaints, delays, and emergency rescues.</span></div></li>
      </ul>
      <a href="#contact" class="btn btn-primary" data-i18n="td_cta">Contact a District Representative →</a>
    </div>
    <div class="tab-visual rv d2">
      <img src="https://safedriveservice.com/wp-content/uploads/2024/08/Mask-group-2-2-1024x683.png" alt="School District Transportation"/>
      <div class="tab-metric-overlay">
        <div class="tmo"><div class="n">95%</div><div class="l" data-i18n="tmo1">Punctuality</div></div>
        <div class="tmo"><div class="n">0</div><div class="l" data-i18n="tmo2">Regulatory Gaps</div></div>
      </div>
    </div>
  </div>

  <div class="tab-panel" id="tab-brokers">
    <div class="tab-text rv">
      <div class="eyebrow" data-i18n="tbe_ey">For Transport Brokers</div>
      <h3 class="tab-title" data-i18n="tbe_title">An Operator That Executes<br>Without Friction.</h3>
      <p class="tab-body" data-i18n="tbe_body">Brokers like EverDriven need operators who deliver — without escalations, without exceptions. Safe Drive is a multi-state structured operator that aligns to your KPIs and SLAs, manages its own protocols, and keeps your accounts stable.</p>
      <ul class="value-list">
        <li><div class="vico">✓</div><div><strong data-i18n="tbe_v1h">KPI and SLA alignment</strong> — <span data-i18n="tbe_v1p">We operate under your metrics. Reporting available on request.</span></div></li>
        <li><div class="vico">✓</div><div><strong data-i18n="tbe_v2h">Multi-state coverage</strong> — <span data-i18n="tbe_v2p">Consistent execution across jurisdictions under a single operator.</span></div></li>
        <li><div class="vico">✓</div><div><strong data-i18n="tbe_v3h">Low operational friction</strong> — <span data-i18n="tbe_v3p">Internal protocols handle escalations before they reach your account team.</span></div></li>
        <li><div class="vico">✓</div><div><strong data-i18n="tbe_v4h">Contractual stability</strong> — <span data-i18n="tbe_v4p">4 years of consistent operation. No sudden capacity failures.</span></div></li>
      </ul>
      <a href="#contact" class="btn btn-primary" data-i18n="tbe_cta">Connect With Our Operations Team →</a>
    </div>
    <div class="tab-visual rv d2">
      <img src="https://safedriveservice.com/wp-content/uploads/2024/08/Mask-group-1-3-1024x683.png" alt="Transport Broker Operations"/>
      <div class="tab-metric-overlay">
        <div class="tmo"><div class="n">KPI</div><div class="l" data-i18n="tmo3">Aligned</div></div>
        <div class="tmo"><div class="n">SLA</div><div class="l" data-i18n="tmo4">Compliant</div></div>
      </div>
    </div>
  </div>

  <div class="tab-panel" id="tab-charter">
    <div class="tab-text rv">
      <div class="eyebrow" data-i18n="tc_ey">For Charter &amp; Private Schools</div>
      <h3 class="tab-title" data-i18n="tc_title">Structured Access.<br>Institutional Accountability.</h3>
      <p class="tab-body" data-i18n="tc_body">Charter and private schools need transport partners who operate under defined standards — not informal arrangements. Safe Drive delivers consistent routes, regulatory compliance, and operational control that protects your institution's reputation and your families' trust.</p>
      <ul class="value-list">
        <li><div class="vico">✓</div><div><strong data-i18n="tc_v1h">Assigned recurring routes</strong> — <span data-i18n="tc_v1p">Stable, predictable operation with no improvised scheduling.</span></div></li>
        <li><div class="vico">✓</div><div><strong data-i18n="tc_v2h">Alternative transport coverage</strong> — <span data-i18n="tc_v2p">Backup capacity for non-standard or emergency transportation needs.</span></div></li>
        <li><div class="vico">✓</div><div><strong data-i18n="tc_v3h">Defined institutional protocols</strong> — <span data-i18n="tc_v3p">Every route follows formal procedures, not ad-hoc arrangements.</span></div></li>
        <li><div class="vico">✓</div><div><strong data-i18n="tc_v4h">Reputational protection</strong> — <span data-i18n="tc_v4p">Incidents reduced through structured control, not luck.</span></div></li>
      </ul>
      <a href="#contact" class="btn btn-primary" data-i18n="tc_cta">Start a Conversation →</a>
    </div>
    <div class="tab-visual rv d2">
      <img src="https://safedriveservice.com/wp-content/uploads/2024/08/7003942-1-1.png" alt="Charter School Transportation"/>
      <div class="tab-metric-overlay">
        <div class="tmo"><div class="n">✓</div><div class="l" data-i18n="tmo5">Structured Routes</div></div>
        <div class="tmo"><div class="n">✓</div><div class="l" data-i18n="tmo6">Institutional Standards</div></div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="sec sec-alt" id="services">
  <div class="sec-hdr center rv">
    <div class="eyebrow" data-i18n="serv_eyebrow">Service Scope</div>
    <h2 class="sec-title" data-i18n="serv_title">What We Execute</h2>
    <p class="sec-sub" data-i18n="serv_sub">All services delivered under defined protocols, regulatory compliance, and operational control. No improvised arrangements.</p>
  </div>
  <div class="grid-3">
    <div class="scard rv"><div class="scard-ico"><img src="https://cdn-icons-gif.flaticon.com/8722/8722506.gif" alt="Assigned Contract Routes"/></div><h3 data-i18n="s1_title">Assigned Contract Routes</h3><p data-i18n="s1_p">Recurring routes executed under contractual agreements with districts and brokers. Predictable, structured, compliant.</p></div>
    <div class="scard rv d1"><div class="scard-ico"><img src="https://cdn-icons-gif.flaticon.com/6449/6449639.gif" alt="Special Needs Transport"/></div><h3 data-i18n="s2_title">Special Needs Transport</h3><p data-i18n="s2_p">Staff trained in defined protocols for students with physical, cognitive, and developmental needs. No exceptions on standards.</p></div>
    <div class="scard rv d2"><div class="scard-ico"><img src="https://cdn-icons-gif.flaticon.com/7308/7308528.gif" alt="Alternative Transport"/></div><h3 data-i18n="s3_title">Alternative Transport</h3><p data-i18n="s3_p">Backup and non-standard transport capacity for institutions needing flexible coverage within a regulated framework.</p></div>
    <div class="scard rv d3"><div class="scard-ico"><img src="https://cdn-icons-gif.flaticon.com/6449/6449670.gif" alt="Sensitive Case Handling"/></div><h3 data-i18n="s4_title">Sensitive Case Handling</h3><p data-i18n="s4_p">Dedicated protocols for high-risk students. Executed with discretion and full institutional accountability.</p></div>
    <div class="scard rv d1"><div class="scard-ico"><img src="https://cdn-icons-gif.flaticon.com/6844/6844486.gif" alt="GPS Monitoring & Tracking"/></div><h3 data-i18n="s5_title">GPS Monitoring &amp; Tracking</h3><p data-i18n="s5_p">Real-time vehicle tracking with event-based logging. Operational visibility for district and broker oversight teams.</p></div>
    <div class="scard rv d2"><div class="scard-ico"><img src="https://cdn-icons-gif.flaticon.com/6454/6454079.gif" alt="School Mobility Program"/></div><h3 data-i18n="s6_title">School Mobility Program</h3><p data-i18n="s6_p">Extended coverage ensuring access to education regardless of geography, under multi-state regulatory compliance.</p></div>
  </div>
</section>

<!-- ABOUT -->
<section class="sec" id="about">
  <div class="about-split">
    <div class="about-img-wrap rv">
      <img src="https://safedriveservice.com/wp-content/uploads/2024/08/Mask-group-1-3-1024x683.png" alt="Safe Drive operations"/>
    </div>
    <div>
      <div class="eyebrow rv" data-i18n="about_eyebrow">About Safe Drive</div>
      <h2 class="sec-title rv d1" data-i18n="about_title">Operational Risk Reduction, Not Just Transportation</h2>
      <p class="sec-sub rv d2" style="max-width:100%" data-i18n="about_sub">Safe Drive Service is a B2B institutional operator with 4 years of multi-state structured operation. The value we deliver is not physical movement — it is the elimination of operational chaos that districts, brokers, and schools cannot afford to absorb.</p>
      <div class="about-checks">
        <div class="acheck rv d2"><div class="acheck-dot">✓</div><div><h4 data-i18n="chk1_h">Compliance Before Speed</h4><p data-i18n="chk1_p">Regulatory compliance is non-negotiable in every jurisdiction we operate. We do not cut corners for capacity.</p></div></div>
        <div class="acheck rv d3"><div class="acheck-dot">✓</div><div><h4 data-i18n="chk2_h">Control Before Improvisation</h4><p data-i18n="chk2_p">Every route operates under defined protocols. No informal arrangements, no ad-hoc decisions on critical routes.</p></div></div>
        <div class="acheck rv d4"><div class="acheck-dot">✓</div><div><h4 data-i18n="chk3_h">Controlled, Strategic Expansion</h4><p data-i18n="chk3_p">We grow within real operational capacity. No commitments beyond our ability to execute with full compliance.</p></div></div>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="sec sec-alt" id="how-it-works">
  <div class="sec-hdr center rv">
    <div class="eyebrow" data-i18n="how_eyebrow">Onboarding Process</div>
    <h2 class="sec-title" data-i18n="how_title">How We Onboard Partners</h2>
    <p class="sec-sub" data-i18n="how_sub">A structured, frictionless process from first contact to full operational execution.</p>
  </div>
  <div class="steps">
    <div class="step-c rv"><div class="step-n">01</div><h3 data-i18n="step1_h">Initial Contact</h3><p data-i18n="step1_p">Connect via form or phone. We assess your district's or account's operational requirements and jurisdictional scope.</p></div>
    <div class="step-c rv d1"><div class="step-n">02</div><h3 data-i18n="step2_h">Route &amp; Scope Review</h3><p data-i18n="step2_p">Our operations team reviews route volume, geography, student profiles, and compliance requirements per state.</p></div>
    <div class="step-c rv d2"><div class="step-n">03</div><h3 data-i18n="step3_h">Contract &amp; Protocol Setup</h3><p data-i18n="step3_p">Formal agreements established. Protocols defined per route type. Driver and monitor assignments confirmed.</p></div>
    <div class="step-c rv d3"><div class="step-n">04</div><h3 data-i18n="step4_h">Live Execution</h3><p data-i18n="step4_p">Fully operational service with GPS monitoring, real-time reporting, and 95% on-time standard from day one.</p></div>
  </div>
</section>

<!-- DRIVE WITH US -->
<section id="drive-with-us">
  <div class="r-glow"></div>
  <div class="r-grid-bg"></div>
  <div class="r-inner">
    <div class="r-cols">
      <div>
        <div class="r-eyebrow rv" data-i18n="hire_eyebrow">We're Hiring</div>
        <h2 class="r-title rv d1" data-i18n="hire_title">Drive With Us.<br>Make a Difference.</h2>
        <p class="r-sub rv d2" data-i18n="hire_sub">Safe Drive is expanding and continuously seeking qualified drivers and student monitors across the United States. Join a structured, professional operation with defined standards and real growth.</p>
        <div class="perks rv d3">
          <div class="perk"><div class="perk-top"><span class="perk-ico"><img src="https://cdn-icons-gif.flaticon.com/9908/9908548.gif" alt=""/></span><h4 data-i18n="perk1_h">Competitive Pay</h4></div><p data-i18n="perk1_p">Attractive hourly rates with route bonuses and performance incentives.</p></div>
          <div class="perk"><div class="perk-top"><span class="perk-ico"><img src="https://cdn-icons-gif.flaticon.com/14456/14456578.gif" alt=""/></span><h4 data-i18n="perk2_h">Flexible Hours</h4></div><p data-i18n="perk2_p">School-hours routes only — no nights or weekends required.</p></div>
          <div class="perk"><div class="perk-top"><span class="perk-ico"><img src="https://cdn-icons-gif.flaticon.com/9566/9566538.gif" alt=""/></span><h4 data-i18n="perk3_h">Benefits Package</h4></div><p data-i18n="perk3_p">Health coverage, paid training, and growth opportunities available.</p></div>
          <div class="perk"><div class="perk-top"><span class="perk-ico"><img src="https://cdn-icons-gif.flaticon.com/10471/10471121.gif" alt=""/></span><h4 data-i18n="perk4_h">Structured Operation</h4></div><p data-i18n="perk4_p">Clear protocols, defined routes, and professional institutional standards.</p></div>
        </div>
      </div>
      <div class="req-panel rv d2">
        <h3>📋 <span data-i18n="req_title">Basic Requirements</span></h3>
        <ul class="req-list">
          <li data-i18n="req1">Valid Driver's License</li>
          <li data-i18n="req2">Clean driving record — last 3 years</li>
          <li data-i18n="req3">Federal &amp; state background check clearance</li>
          <li data-i18n="req4">Minimum 21 years of age</li>
          <li data-i18n="req5">High school diploma or equivalent</li>
          <li data-i18n="req6">Drug screening clearance</li>
          <li data-i18n="req7">Basic English communication skills</li>
          <li data-i18n="req8">CPR / First Aid certified (or willing to obtain)</li>
          <li data-i18n="req9">Reliable, punctual, and professional attitude</li>
          <li data-i18n="req10">Prior experience with children is a plus</li>
        </ul>
      </div>
    </div>
    <div class="vehicle-strip rv">
      <img src="https://safedriveservice.com/wp-content/uploads/2024/08/Group-5-1-1024x1024.png" alt="Safe Drive Van 1"/>
      <img src="https://safedriveservice.com/wp-content/uploads/2024/08/Group-5-3-1024x1024.png" alt="Safe Drive Van 2"/>
    </div>
    <div class="r-divider"></div>
    <div class="r-cta-box rv">

      <h2 data-i18n="cta_title">Ready to Join Our Team?</h2>
      <p data-i18n="cta_sub">Fill out our quick application — it takes under 3 minutes. We'll be in touch within 48 hours.</p>
      <div class="cta-acts">
        <a href="https://docs.google.com/forms/d/e/1FAIpQLScZ1QY8i71dFQGX-NvmzfLqV6Sir4jk2LRB3V-6WUGcdTZsdA/viewform" target="_blank" class="btn btn-gold">📝 <span data-i18n="apply_btn">Apply Now</span></a>
        <a href="tel:+14078201996" class="btn btn-wout">📞 (407) 820-1996</a>
      </div>
    </div>
  </div>
</section>

