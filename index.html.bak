<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Safe Drive Services – Institutional School Transportation</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700;800;900&family=Source+Sans+3:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap" rel="stylesheet"/>
  <style>
  :root{
    --bg:#F5F5F3;--bg2:#EBEBEA;--surface:#FFFFFF;--border:rgba(0,0,0,.09);
    --text:#1A1A1A;--text-muted:#666260;
    --accent:#1A3D8F;--accent-h:#152F6E;--accent-lt:#E8EEF9;
    --gold:#D4920A;--gold-lt:#FFF5DC;
    --navy:#0C1E45;
    --nav-bg:rgba(245,245,243,.88);
    --sh:0 2px 20px rgba(0,0,0,.07);--sh-lg:0 8px 40px rgba(0,0,0,.12);
    --r:16px;--ease:.32s cubic-bezier(.4,0,.2,1);
  }
  [data-theme="dark"]{
    --bg:#0E1117;--bg2:#161B26;--surface:#1C2336;--border:rgba(255,255,255,.08);
    --text:#E8EAF0;--text-muted:#8A93AB;
    --accent:#4B72D4;--accent-h:#5C82E2;--accent-lt:#172046;
    --gold:#F5B93A;--gold-lt:#2A1F04;
    --navy:#060E22;
    --nav-bg:rgba(14,17,23,.92);
    --sh:0 2px 20px rgba(0,0,0,.3);--sh-lg:0 8px 40px rgba(0,0,0,.4);
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{font-family:'Source Sans 3',sans-serif;background:var(--bg);color:var(--text);transition:background var(--ease),color var(--ease);overflow-x:hidden;line-height:1.6;}
  img{max-width:100%;display:block;}
  a{color:inherit;text-decoration:none;}
  h1,h2,h3,h4,h5{font-family:'Raleway',sans-serif;line-height:1.15;font-weight:700;}

  .fl-logo{position:fixed;top:14px;left:24px;z-index:200;}
  .fl-logo img{height:46px;width:auto;filter:drop-shadow(0 2px 8px rgba(0,0,0,.25));transition:height var(--ease);}
  [data-theme="dark"] .fl-logo img{filter:brightness(1.15) drop-shadow(0 2px 8px rgba(0,0,0,.5));}
  @media(max-width:680px){.fl-logo img{height:36px;}}

  .top-controls{position:fixed;top:14px;right:14px;z-index:200;display:flex;gap:8px;align-items:center;}
  .lang-btn{height:38px;border-radius:99px;border:none;background:var(--surface);box-shadow:var(--sh);cursor:pointer;display:flex;align-items:center;color:var(--text);transition:box-shadow var(--ease);overflow:hidden;font-family:'Raleway',sans-serif;font-weight:700;font-size:.78rem;letter-spacing:.04em;}
  .lang-btn:hover{box-shadow:var(--sh-lg);}
  .lang-opt{padding:0 13px;height:100%;display:flex;align-items:center;transition:background var(--ease),color var(--ease);}
  .lang-opt.active{background:var(--accent);color:#fff;}
  .lang-divider{width:1px;height:60%;background:var(--border);}
  .theme-btn{width:38px;height:38px;border-radius:50%;border:none;background:var(--surface);box-shadow:var(--sh);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text);transition:transform .2s,box-shadow var(--ease);}
  .theme-btn:hover{transform:scale(1.12);box-shadow:var(--sh-lg);}
  .theme-btn svg{width:17px;height:17px;stroke:currentColor;stroke-width:2.2;fill:none;stroke-linecap:round;stroke-linejoin:round;}
  .icon-moon{display:none;}
  [data-theme="dark"] .icon-sun{display:none;}
  [data-theme="dark"] .icon-moon{display:block;}

  .nav{position:fixed;top:0;left:0;right:0;z-index:150;display:flex;align-items:center;justify-content:flex-end;padding:0 160px;height:70px;background:transparent;transition:background var(--ease),backdrop-filter var(--ease),border-color var(--ease),transform .38s cubic-bezier(.4,0,.2,1);border-bottom:1px solid transparent;}
  .nav.scrolled{background:var(--nav-bg);backdrop-filter:blur(18px);border-color:var(--border);}
  .nav.hidden{transform:translateY(-100%);}
  .nav-links{display:flex;align-items:center;gap:4px;list-style:none;}
  .nav-links a{font-family:'Raleway',sans-serif;font-size:.83rem;font-weight:600;letter-spacing:.03em;padding:7px 11px;border-radius:8px;color:rgba(255,255,255,.75);transition:color var(--ease),background var(--ease);}
  .nav-links a:hover{color:#fff;background:rgba(255,255,255,.1);}
  .nav-links a.ncta{background:var(--accent);color:#fff;margin-left:6px;padding:7px 14px;}
  .nav-links a.ncta:hover{background:var(--accent-h);}
  .nav.scrolled .nav-links a{color:var(--text-muted);}
  .nav.scrolled .nav-links a:hover{color:var(--text);background:var(--bg2);}
  .nav.scrolled .nav-links a.ncta{color:#fff;background:var(--accent);}
  .hbg{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px;}
  .hbg span{width:22px;height:2px;border-radius:2px;background:var(--text);display:block;transition:all .28s;}
  .nav:not(.scrolled) .hbg span{background:#fff;}
  .hbg.open span:nth-child(1){transform:rotate(45deg) translate(5px,5px);}
  .hbg.open span:nth-child(2){opacity:0;}
  .hbg.open span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px);}
  @media(max-width:980px){.nav-links{display:none;}.hbg{display:flex;}.nav{padding:0 100px 0 160px;}}
  .mob-nav{display:none;position:fixed;top:70px;left:0;right:0;z-index:149;background:var(--surface);border-bottom:1px solid var(--border);box-shadow:var(--sh-lg);flex-direction:column;padding:12px 20px 20px;gap:4px;}
  .mob-nav.open{display:flex;}
  .mob-nav a{font-family:'Raleway',sans-serif;font-weight:600;font-size:.97rem;padding:11px 16px;border-radius:9px;color:var(--text);transition:background var(--ease);}
  .mob-nav a:hover{background:var(--bg2);}
  .mob-nav a.ncta{background:var(--accent);color:#fff;text-align:center;margin-top:6px;}

  .btn{display:inline-flex;align-items:center;gap:8px;padding:12px 24px;border-radius:10px;font-family:'Raleway',sans-serif;font-weight:700;font-size:.92rem;letter-spacing:.02em;cursor:pointer;border:none;transition:all var(--ease);}
  .btn-primary{background:var(--accent);color:#fff;}
  .btn-primary:hover{background:var(--accent-h);transform:translateY(-2px);box-shadow:0 6px 24px rgba(26,61,143,.4);}
  .btn-ghost{background:rgba(255,255,255,.1);color:#fff;border:1.5px solid rgba(255,255,255,.3);backdrop-filter:blur(8px);}
  .btn-ghost:hover{background:rgba(255,255,255,.18);transform:translateY(-2px);}
  .btn-gold{background:var(--gold);color:#1A0F00;box-shadow:0 4px 20px rgba(212,146,10,.4);}
  .btn-gold:hover{filter:brightness(1.06);transform:translateY(-2px);box-shadow:0 8px 32px rgba(212,146,10,.5);}
  .btn-wout{background:transparent;border:1.5px solid rgba(255,255,255,.28);color:#fff;}
  .btn-wout:hover{background:rgba(255,255,255,.08);transform:translateY(-2px);}

  /* HERO */
  .hero{min-height:100vh;position:relative;display:flex;align-items:center;overflow:hidden;}
  .hero-bg-static{position:absolute;inset:0;z-index:0;background:linear-gradient(138deg,rgba(12,30,69,.93) 0%,rgba(26,61,143,.78) 55%,rgba(12,30,69,.65) 100%),url('https://safedriveservice.com/wp-content/uploads/2024/08/Mask-group-2-2-1024x683.png') center/cover no-repeat;}
  [data-theme="dark"] .hero-bg-static{background:linear-gradient(138deg,rgba(6,14,34,.96) 0%,rgba(12,30,69,.9) 55%,rgba(6,14,34,.8) 100%),url('https://safedriveservice.com/wp-content/uploads/2024/08/Mask-group-2-2-1024x683.png') center/cover no-repeat;}
  .hero-video-wrap{position:absolute;inset:0;z-index:1;overflow:hidden;}
  .hero-video-wrap video{width:100%;height:100%;object-fit:cover;display:block;}
  .hero-video-wrap::after{content:'';position:absolute;inset:0;background:linear-gradient(138deg,rgba(12,30,69,.88) 0%,rgba(26,61,143,.62) 55%,rgba(12,30,69,.72) 100%);z-index:1;}
  [data-theme="dark"] .hero-video-wrap::after{background:linear-gradient(138deg,rgba(6,14,34,.94) 0%,rgba(12,30,69,.88) 55%,rgba(6,14,34,.78) 100%);}
  .hero-content{position:relative;z-index:3;padding:130px 8% 80px;max-width:820px;}
  .hero-eyebrow{display:inline-flex;align-items:center;gap:10px;font-family:'Raleway',sans-serif;font-size:.73rem;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:var(--gold);margin-bottom:22px;}
  .hero-eyebrow::before{content:'';width:26px;height:2px;background:var(--gold);}
  .hero h1{font-size:clamp(2.5rem,5vw,4.1rem);font-weight:900;color:#fff;letter-spacing:-.02em;margin-bottom:20px;}
  .hero h1 em{color:var(--gold);font-style:normal;}
  .hero p{font-size:1.05rem;color:rgba(255,255,255,.72);max-width:580px;line-height:1.78;margin-bottom:38px;}
  .hero-ctas{display:flex;gap:12px;flex-wrap:wrap;}
  .hero-stats{display:flex;flex-wrap:wrap;gap:0;margin-top:52px;padding-top:30px;border-top:1px solid rgba(255,255,255,.14);}
  .hstat{padding-right:32px;margin-right:32px;border-right:1px solid rgba(255,255,255,.12);}
  .hstat:last-child{border-right:none;}
  .hstat .n{font-family:'Raleway',sans-serif;font-size:2rem;font-weight:900;color:var(--gold);line-height:1;margin-bottom:4px;}
  .hstat .l{font-size:.76rem;color:rgba(255,255,255,.52);font-weight:500;}

  /* SECTIONS */
  .sec{padding:88px 8%;}
  .sec-alt{background:var(--bg2);}
  .eyebrow{font-family:'Raleway',sans-serif;font-size:.72rem;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:var(--accent);display:flex;align-items:center;gap:10px;margin-bottom:12px;}
  .eyebrow::before{content:'';width:22px;height:2px;background:var(--accent);}
  .sec-title{font-size:clamp(1.8rem,3vw,2.55rem);font-weight:800;letter-spacing:-.02em;margin-bottom:14px;}
  .sec-sub{font-size:1.02rem;color:var(--text-muted);line-height:1.78;max-width:560px;}
  .sec-hdr{margin-bottom:50px;}
  .sec-hdr.center{text-align:center;}
  .sec-hdr.center .eyebrow{justify-content:center;}
  .sec-hdr.center .sec-sub{margin:0 auto;}

  /* TRUST BAR */
  .trust-bar{background:var(--navy);padding:16px 8%;display:flex;align-items:center;justify-content:center;gap:32px;flex-wrap:wrap;}
  [data-theme="dark"] .trust-bar{background:#060911;}
  .trust-item{display:flex;align-items:center;gap:8px;font-family:'Raleway',sans-serif;font-size:.77rem;font-weight:600;color:rgba(255,255,255,.62);letter-spacing:.04em;text-transform:uppercase;}
  .trust-sep{width:1px;height:18px;background:rgba(255,255,255,.15);}
  @media(max-width:680px){.trust-sep{display:none;}.trust-bar{gap:14px;}}

  /* METRICS STRIP */
  #metrics{background:var(--accent);padding:60px 8%;}
  [data-theme="dark"] #metrics{background:#152F6E;}
  .metrics-inner{display:grid;grid-template-columns:1fr 2px 1fr 2px 1fr 2px 1fr;gap:0;align-items:center;}
  @media(max-width:860px){.metrics-inner{grid-template-columns:1fr 1fr;gap:24px;}.metrics-sep{display:none;}}
  @media(max-width:480px){.metrics-inner{grid-template-columns:1fr;}}
  .metric-item{text-align:center;padding:10px 20px;}
  .metric-n{font-family:'Raleway',sans-serif;font-size:2.8rem;font-weight:900;color:#fff;line-height:1;margin-bottom:8px;}
  .metric-n sup{font-size:1.1rem;vertical-align:super;}
  .metric-l{font-size:.8rem;color:rgba(255,255,255,.65);font-weight:500;line-height:1.5;}
  .metrics-sep{width:2px;height:60px;background:rgba(255,255,255,.18);}

  /* AUDIENCE TABS */
  #partners{background:var(--bg);}
  .tab-nav{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:40px;border-bottom:2px solid var(--border);padding-bottom:0;}
  .tab-btn{font-family:'Raleway',sans-serif;font-size:.88rem;font-weight:700;padding:12px 20px;border:none;background:transparent;color:var(--text-muted);cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-2px;transition:color var(--ease),border-color var(--ease);display:inline-flex;align-items:center;gap:8px;}
  .tab-btn img{width:22px;height:22px;object-fit:contain;opacity:.7;transition:opacity var(--ease);}
  .tab-btn:hover img,.tab-btn.active img{opacity:1;}
  .tab-btn:hover{color:var(--text);}
  .tab-btn.active{color:var(--accent);border-bottom-color:var(--accent);}
  .tab-panel{display:none;}
  .tab-panel.active{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;}
  @media(max-width:860px){.tab-panel.active{grid-template-columns:1fr;gap:32px;}}
  .tab-title{font-size:clamp(1.55rem,2.8vw,2.1rem);font-weight:800;letter-spacing:-.02em;margin-bottom:14px;}
  .tab-body{font-size:.98rem;color:var(--text-muted);line-height:1.82;margin-bottom:24px;}
  .value-list{list-style:none;display:flex;flex-direction:column;gap:12px;margin-bottom:28px;}
  .value-list li{display:flex;align-items:flex-start;gap:11px;font-size:.92rem;line-height:1.6;}
  .value-list li .vico{width:22px;height:22px;flex-shrink:0;border-radius:6px;background:var(--accent-lt);color:var(--accent);font-size:.7rem;font-weight:800;display:flex;align-items:center;justify-content:center;margin-top:2px;}
  .tab-visual{border-radius:18px;overflow:hidden;box-shadow:var(--sh-lg);position:relative;}
  .tab-visual img{width:100%;aspect-ratio:4/3;object-fit:cover;display:block;}
  .tab-metric-overlay{position:absolute;bottom:18px;left:18px;right:18px;display:flex;gap:10px;}
  .tmo{flex:1;background:rgba(12,30,69,.82);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.14);border-radius:12px;padding:14px;text-align:center;}
  .tmo .n{font-family:'Raleway',sans-serif;font-size:1.5rem;font-weight:900;color:var(--gold);line-height:1;}
  .tmo .l{font-size:.68rem;color:rgba(255,255,255,.6);margin-top:4px;}

  /* SERVICES */
  .grid-3{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:18px;}
  .scard{background:#EDF1FB;border:1px solid var(--border);border-radius:var(--r);padding:28px;box-shadow:var(--sh);transition:transform var(--ease),box-shadow var(--ease);position:relative;overflow:hidden;}
  [data-theme="dark"] .scard{background:#1F2A45;}
  .scard::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--accent);transform:scaleX(0);transform-origin:left;transition:transform var(--ease);}
  .scard:hover::before{transform:scaleX(1);}
  .scard:hover{transform:translateY(-4px);box-shadow:var(--sh-lg);}
  .scard-ico{width:50px;height:50px;border-radius:12px;background:#FFFFFF;display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:18px;box-shadow:0 2px 8px rgba(0,0,0,.10);}
  [data-theme="dark"] .scard-ico{background:rgba(255,255,255,.93);}
  .scard-ico img{width:32px;height:32px;object-fit:contain;}
  .scard h3{font-size:1rem;font-weight:700;margin-bottom:8px;}
  .scard p{font-size:.87rem;color:var(--text-muted);line-height:1.72;}

  /* ABOUT */
  .about-split{display:grid;grid-template-columns:1fr 1fr;gap:68px;align-items:center;}
  .about-img-wrap{position:relative;}
  .about-img-wrap img{border-radius:18px;width:100%;object-fit:cover;box-shadow:var(--sh-lg);}
  .about-img-wrap::after{content:'';position:absolute;bottom:-14px;right:-14px;width:65%;height:65%;background:var(--accent-lt);border-radius:18px;z-index:-1;}
  .about-checks{display:flex;flex-direction:column;gap:16px;margin:26px 0;}
  .acheck{display:flex;gap:13px;}
  .acheck-dot{width:24px;height:24px;flex-shrink:0;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700;margin-top:2px;}
  .acheck h4{font-size:.94rem;font-weight:700;margin-bottom:3px;}
  .acheck p{font-size:.86rem;color:var(--text-muted);line-height:1.62;}
  @media(max-width:900px){.about-split{grid-template-columns:1fr;gap:36px;}.about-img-wrap{max-width:500px;}}

  /* STEPS */
  .steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:18px;}
  .step-c{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:26px;box-shadow:var(--sh);position:relative;transition:transform var(--ease);}
  .step-c:hover{transform:translateY(-3px);}
  .step-c:not(:last-child)::after{content:'→';position:absolute;right:-11px;top:50%;transform:translateY(-50%);color:var(--accent);font-size:1.1rem;font-weight:700;z-index:2;}
  .step-n{font-family:'Raleway',sans-serif;font-size:2.6rem;font-weight:900;color:var(--accent-lt);line-height:1;margin-bottom:12px;}
  .step-c h3{font-size:1rem;font-weight:700;margin-bottom:7px;}
  .step-c p{font-size:.86rem;color:var(--text-muted);line-height:1.65;}
  @media(max-width:680px){.step-c:not(:last-child)::after{display:none;}}

  /* RECRUITMENT */
  #drive-with-us{background:var(--navy);position:relative;overflow:hidden;padding:88px 8%;}
  [data-theme="dark"] #drive-with-us{background:#060911;}
  .r-glow{pointer-events:none;position:absolute;inset:0;z-index:0;background:radial-gradient(ellipse 55% 55% at 85% 15%,rgba(75,114,212,.22),transparent 60%),radial-gradient(ellipse 40% 50% at 10% 88%,rgba(212,146,10,.12),transparent 55%);}
  .r-grid-bg{pointer-events:none;position:absolute;inset:0;z-index:0;opacity:.032;background-image:linear-gradient(rgba(255,255,255,1) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,1) 1px,transparent 1px);background-size:48px 48px;}
  .r-inner{position:relative;z-index:1;}
  .r-cols{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start;margin-bottom:60px;}
  @media(max-width:900px){.r-cols{grid-template-columns:1fr;gap:42px;}}
  .r-eyebrow{font-family:'Raleway',sans-serif;font-size:.72rem;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:10px;margin-bottom:12px;}
  .r-eyebrow::before{content:'';width:22px;height:2px;background:var(--gold);}
  .r-title{font-family:'Raleway',sans-serif;font-size:clamp(2rem,3.4vw,3rem);font-weight:900;letter-spacing:-.02em;color:#fff;margin-bottom:16px;}
  .r-sub{font-size:1rem;color:rgba(255,255,255,.6);line-height:1.78;margin-bottom:34px;}
  .perks{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
  @media(max-width:500px){.perks{grid-template-columns:1fr;}}
  .perk{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:16px;transition:background var(--ease);}
  .perk:hover{background:rgba(255,255,255,.09);}
  .perk-top{display:flex;align-items:center;gap:9px;margin-bottom:5px;}
  .perk-ico{display:flex;align-items:center;justify-content:center;width:24px;height:24px;}
  .perk-ico img{width:100%;height:100%;object-fit:contain;}
  .perk h4{font-family:'Raleway',sans-serif;font-size:.88rem;font-weight:700;color:#fff;}
  .perk p{font-size:.78rem;color:rgba(255,255,255,.5);line-height:1.55;}
  .req-panel{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:30px;}
  .req-panel h3{font-family:'Raleway',sans-serif;font-size:1.08rem;font-weight:700;color:#fff;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid rgba(255,255,255,.09);display:flex;align-items:center;gap:9px;}
  .req-list{list-style:none;display:flex;flex-direction:column;gap:9px;}
  .req-list li{display:flex;align-items:flex-start;gap:9px;font-size:.86rem;color:rgba(255,255,255,.68);line-height:1.5;}
  .req-list li::before{content:'✓';color:var(--gold);font-weight:700;flex-shrink:0;margin-top:1px;}
  .r-divider{height:1px;background:rgba(255,255,255,.08);margin-bottom:60px;}
  .pos-row{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-bottom:30px;}
  .pos-badge{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:99px;font-size:.85rem;color:rgba(255,255,255,.78);font-family:'Raleway',sans-serif;font-weight:600;transition:background var(--ease);}
  .pos-badge:hover{background:rgba(255,255,255,.12);}
  .r-cta-box{text-align:center;padding:50px 36px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:18px;position:relative;overflow:hidden;}
  .r-cta-box::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--accent),var(--gold));}
  .r-cta-box h2{font-family:'Raleway',sans-serif;font-size:clamp(1.75rem,2.8vw,2.4rem);font-weight:900;color:#fff;margin-bottom:10px;}
  .r-cta-box p{color:rgba(255,255,255,.58);font-size:.98rem;margin-bottom:30px;}
  .cta-acts{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
  @media(max-width:480px){.cta-acts{flex-direction:column;align-items:center;}}
  .vehicle-strip{display:flex;gap:14px;margin-bottom:48px;}
  .vehicle-strip img{flex:1;min-width:0;border-radius:14px;object-fit:cover;height:180px;box-shadow:0 6px 24px rgba(0,0,0,.28);transition:transform .3s ease;}
  .vehicle-strip img:hover{transform:scale(1.03);}
  @media(max-width:600px){.vehicle-strip{flex-direction:column;}.vehicle-strip img{height:160px;}}

  /* TEAM */
  .team-grid{display:flex;flex-wrap:wrap;justify-content:center;gap:24px;}
  .team-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);overflow:visible;box-shadow:var(--sh);transition:box-shadow var(--ease);text-align:center;position:relative;cursor:pointer;z-index:1;width:200px;flex-shrink:0;}
  .team-card-inner{overflow:visible;border-radius:var(--r);padding-top:14px;}
  .team-card img{width:78%;margin:0 auto;aspect-ratio:1;object-fit:cover;object-position:top center;display:block;border-radius:50%;box-shadow:0 4px 18px rgba(0,0,0,.18);transition:transform .45s cubic-bezier(.34,1.56,.64,1),box-shadow .45s cubic-bezier(.4,0,.2,1);}
  .team-card:hover img,.team-card.zoomed img{transform:scale(1.45);box-shadow:0 18px 52px rgba(26,61,143,.38),0 0 0 4px var(--accent);}
  .team-card:hover,.team-card.zoomed{box-shadow:var(--sh-lg);z-index:10;}
  .team-info{padding:12px 10px 16px;}
  .team-info h3{font-size:.88rem;font-weight:700;margin-bottom:4px;}
  .team-info p{font-size:.68rem;color:var(--accent);font-family:'Raleway',sans-serif;font-weight:700;text-transform:uppercase;letter-spacing:.07em;}
  #team{position:relative;overflow:hidden;}
  #team::before{content:'';position:absolute;inset:0;background:url('https://i.pinimg.com/originals/20/e6/a4/20e6a4f470b3a19b80694b13c099d854.gif') center/cover no-repeat;opacity:.13;z-index:0;}
  [data-theme="dark"] #team::before{opacity:.07;}
  #team .sec-hdr,#team .team-grid{position:relative;z-index:1;}

  /* COVERAGE MAP */
  #coverage{background:var(--bg);position:relative;overflow:hidden;}
  .map-wrap{max-width:900px;margin:0 auto;padding:40px 20px;}
  #us-map{width:100%;height:auto;filter:drop-shadow(var(--sh));max-height:550px;}
  .state{fill:var(--surface);stroke:var(--border);stroke-width:1;}
  [data-theme="dark"] .state{fill:#222C42;}
  
  .state.active{fill:#A9CFFF;cursor:pointer;transition:all var(--ease);stroke:var(--accent);stroke-width:1.5;}
  .state.active:hover{fill:#387EE3;transform:translateY(-2px);}
  
  .map-tooltip{
    position:absolute;top:0;left:0;
    pointer-events:none;opacity:0;
    background:var(--surface);border:1px solid var(--border);
    padding:12px 16px;border-radius:12px;box-shadow:var(--sh-lg);
    z-index:999;transition:opacity .2s ease;font-family:'Source Sans 3',sans-serif;
  }
  .tt-hdr{font-size:1.1rem;font-weight:700;font-family:'Raleway',sans-serif;margin-bottom:4px;color:var(--text);}
  .tt-row{font-size:.85rem;color:var(--text-muted);display:flex;justify-content:space-between;gap:12px;}
  .tt-val{font-weight:600;color:var(--accent);}

  /* CONTACT */
  .contact-grid{display:grid;grid-template-columns:1fr 1.35fr;gap:52px;align-items:start;}
  @media(max-width:900px){.contact-grid{grid-template-columns:1fr;}}
  .contact-cards{display:flex;flex-direction:column;gap:14px;}
  .cc{background:var(--surface);border:1px solid var(--border);border-radius:13px;padding:18px 20px;display:flex;gap:14px;align-items:center;box-shadow:var(--sh);transition:transform var(--ease);}
  .cc:hover{transform:translateX(4px);}
  .cc-ico{width:44px;height:44px;flex-shrink:0;border-radius:11px;background:var(--accent-lt);color:var(--accent);font-size:1.2rem;display:flex;align-items:center;justify-content:center;}
  .cc-ico img{width:26px;height:26px;object-fit:contain;}
  .cc h4{font-size:.76rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text-muted);margin-bottom:3px;}
  .cc p{font-size:.93rem;font-weight:500;}
  .cf-box{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:34px;box-shadow:var(--sh);}
  .cf-box h3{font-size:1.25rem;font-weight:800;margin-bottom:22px;}
  .f-row{display:grid;grid-template-columns:1fr 1fr;gap:11px;}
  @media(max-width:500px){.f-row{grid-template-columns:1fr;}}
  .field{display:flex;flex-direction:column;gap:5px;margin-bottom:12px;}
  .field label{font-size:.8rem;font-weight:600;color:var(--text-muted);font-family:'Raleway',sans-serif;letter-spacing:.03em;}
  .field input,.field textarea,.field select{padding:10px 13px;border:1.5px solid var(--border);border-radius:9px;background:var(--bg2);color:var(--text);font-family:'Source Sans 3',sans-serif;font-size:.92rem;outline:none;transition:border-color var(--ease),background var(--ease);}
  .field input:focus,.field textarea:focus,.field select:focus{border-color:var(--accent);background:var(--surface);}
  .field textarea{min-height:95px;resize:vertical;}
  .f-submit{width:100%;justify-content:center;font-size:.95rem;padding:13px;}

  /* FOOTER */
  footer{background:var(--navy);color:rgba(255,255,255,.62);padding:56px 8% 26px;}
  [data-theme="dark"] footer{background:#060911;}
  .ft-grid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:44px;margin-bottom:40px;}
  @media(max-width:680px){.ft-grid{grid-template-columns:1fr;}}
  .ft-brand img{height:38px;width:auto;filter:brightness(0) invert(1) opacity(.88);margin-bottom:14px;}
  .ft-brand p{font-size:.86rem;line-height:1.7;max-width:280px;}
  .ft-social{display:flex;gap:9px;margin-top:18px;}
  .soc-btn{width:34px;height:34px;border-radius:8px;border:1px solid rgba(255,255,255,.13);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.65);transition:background .2s,border-color .2s;}
  .soc-btn:hover{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.3);color:#fff;}
  .soc-btn svg{width:15px;height:15px;stroke:currentColor;stroke-width:2;fill:none;stroke-linecap:round;stroke-linejoin:round;}
  footer h4{font-family:'Raleway',sans-serif;font-size:.76rem;font-weight:700;color:#fff;text-transform:uppercase;letter-spacing:.08em;margin-bottom:16px;}
  footer ul{list-style:none;display:flex;flex-direction:column;gap:8px;}
  footer ul li a{font-size:.86rem;transition:color .2s;}
  footer ul li a:hover{color:#fff;}
  .ft-bottom{border-top:1px solid rgba(255,255,255,.08);padding-top:22px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;font-size:.8rem;}

  .rv{opacity:0;transform:translateY(22px);transition:opacity .6s ease,transform .6s ease;}
  .rv.in{opacity:1;transform:none;}
  .d1{transition-delay:.08s;}.d2{transition-delay:.16s;}.d3{transition-delay:.24s;}.d4{transition-delay:.32s;}
  </style>
</head>
<body>

<a class="fl-logo" href="#home"><img src="https://safedriveservice.com/wp-content/uploads/2024/08/logo-original-copia-1.png" alt="Safe Drive Services"/></a>

<div class="top-controls">
